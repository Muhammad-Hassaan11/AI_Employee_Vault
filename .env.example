# AI Employee Vault configuration
# Copy this file to .env and fill in real values. .env is gitignored.
#
# PLATINUM SECURITY RULE: the vault syncs via git, but .env NEVER does.
# The Cloud VM's .env holds ONLY cloud-zone values (Gmail read, LinkedIn,
# Odoo). WhatsApp/Twilio, SMTP send, and any payment/banking credentials
# exist ONLY on the Local machine.

# --- Agent role (Platinum) ----------------------------------------------
# local  = your PC (approvals, WhatsApp, payments, final send/post)
# cloud  = the always-on VM (email triage, draft replies, social drafts)
AGENT_ROLE=local

# --- Gmail watcher (IMAP) + SMTP sending -------------------------------
# Create an App Password at https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_POLL_FOLDER=INBOX

# --- Email MCP server / approval executor (SMTP) -----------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# --- WhatsApp watcher (Twilio) ------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_TO=+14155238886

# --- LinkedIn poster ------------------------------------------------------
# Token needs the w_member_social scope; URN from GET /v2/userinfo -> "sub"
LINKEDIN_ACCESS_TOKEN=your_access_token
LINKEDIN_PERSON_URN=urn:li:person:xxxxxxxx

# --- Odoo accounting (self-hosted, see Odoo/docker-compose.yml) ----------
# Cloud deploy (Odoo/docker-compose.cloud.yml): set ODOO_URL to
# https://<ODOO_DOMAIN> and fill the two cloud values below.
ODOO_URL=http://localhost:8069
ODOO_DB=business
ODOO_USER=admin
ODOO_PASSWORD=your_odoo_password_or_api_key
# Cloud only: DNS name Caddy serves with automatic HTTPS + a real DB password
ODOO_DOMAIN=odoo.example.com
ODOO_DB_PASSWORD=change_me_strong_password

# --- Facebook Page + Instagram Business (Meta Graph API) -----------------
# Page access token with pages_manage_posts + instagram_content_publish
META_PAGE_ID=1234567890
META_PAGE_ACCESS_TOKEN=your_page_access_token
IG_USER_ID=17840000000000000

# --- Twitter / X (API v2, OAuth 1.0a user context) ------------------------
X_API_KEY=your_consumer_key
X_API_SECRET=your_consumer_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_SECRET=your_access_token_secret
